{
  "name": "@life-ai-tools/claude-max-proxy",
  "version": "0.1.0",
  "description": "Transparent Anthropic-native proxy for Claude Code CLI with cache-keepalive protection",
  "type": "module",
  "bin": {
    "claude-max": "./bin/claude-max"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@life-ai-tools/claude-code-sdk": "file:../..",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "claude-code",
    "claude-max",
    "proxy",
    "keepalive",
    "cache"
  ]
}
