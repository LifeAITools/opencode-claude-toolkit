{
  "name": "@life-ai-tools/opencode-claude",
  "version": "1.2.0",
  "description": "OpenCode plugin + AI SDK provider for Claude Max/Pro subscription \u2014 OAuth login, streaming, tool use via claude-code-sdk",
  "type": "module",
  "exports": {
    ".": "./dist/provider.js",
    "./server": "./dist/index.js",
    "./tui": "./tui.tsx"
  },
  "main": "./dist/provider.js",
  "files": [
    "dist/",
    "tui.tsx",
    "wake-preferences.ts",
    "wake-listener.ts",
    "wake-types.ts"
  ],
  "scripts": {
    "build": "bun build provider.ts --target=bun --outfile=dist/provider.js && bun build index.ts --target=bun --outfile=dist/index.js",
    "test": "bun test"
  },
  "dependencies": {
    "@life-ai-tools/claude-code-sdk": "^0.11.0",
    "@life-ai-tools/opencode-signal-wire": "^0.1.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "claude",
    "anthropic",
    "claude-max",
    "oauth",
    "ai-sdk",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LifeAITools/opencode-claude-toolkit"
  },
  "license": "MIT",
  "engines": {
    "opencode": ">=1.0.0"
  }
}
