    "launch": "bun run launch.ts",
    "dev": "bun run --watch server.ts",
    "install-global": "bash install.sh"
  },
  "dependencies": {
    "@life-ai-tools/claude-code-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "opencode",
    "claude",
    "proxy",
    "openai-compatible",
    "claude-max"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LifeAITools/opencode-claude-toolkit"
  },
