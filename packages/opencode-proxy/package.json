{
  "name": "@life-ai-tools/opencode-proxy",
  "version": "0.1.1",
  "description": "OpenAI-compatible proxy — use Claude Max/Pro subscription in opencode, Cursor, or any OpenAI-compatible client",
  "type": "module",
  "bin": {
    "opencode-claude": "./launch.ts",
    "opencode-proxy": "./server.ts"
  },
  "scripts": {
